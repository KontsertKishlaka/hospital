@model IEnumerable<HospitalApp.ViewModels.AppointmentHistoryViewModel>
@{
    ViewData["Title"] = "История посещений";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Назад</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light shadow-sm">
            <h4 class="alert-heading text-muted">История посещений пуста</h4>
            <p class="mb-0 text-muted">Вы еще не посещали нашу поликлинику.</p>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm">
            <table class="table table-hover align-middle border">
                <thead class="table-secondary">
                    <tr>
                        <th>Дата и время</th>
                        <th>Услуга</th>
                        <th>Врач</th>
                        <th>Стоимость</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.DateService.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@item.ServiceTitle</td>
                            <td>@item.DoctorShortName</td>
                            <td class="fw-bold">@item.Cost.ToString("C2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
